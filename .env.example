# Agent Passport configuration. Copy to .env and fill in.
# Do NOT commit .env — it is in .gitignore for a reason.

# --- CSP (Credential Service Provider) — OIDC + PKCE ---
# Works with any OIDC provider that supports PKCE. Configuration is
# discovery-driven (RFC 8414 / OIDC Discovery 1.0): only the discovery URL
# is hardcoded; every other endpoint (jwks_uri, token_endpoint,
# authorization_endpoint) is resolved from
# <issuer>/.well-known/openid-configuration. Verify the exact discovery URL,
# scope names, and acr URIs against your CSP's docs before relying on them.

CSP_CLIENT_ID=
CSP_CLIENT_SECRET=
CSP_REDIRECT_URI=http://localhost:8765/callback
CSP_DISCOVERY_URL=https://your-csp.example.com/.well-known/openid-configuration
CSP_SCOPES="openid"

# --- ACR -> NIST 800-63-3 IAL/AAL/FAL mapping ---
# Selects which ACR mapping the CLI uses:
#   ial                (default) -- NIST 800-63-3 `.../ial/N` URIs plus the
#                                   legacy `.../loa/1` and `.../loa/3` that
#                                   several CSPs still emit.
#   pkg.module:func    -- import path to a custom AcrMapping function for
#                         CSPs that emit URIs outside the built-in set.
# CSP_ACR_MAPPING=ial

# --- Agent Passport issuer signing key ---
# Path to a PEM-encoded RSA or Ed25519 private key. If unset, the issuer
# generates an ephemeral keypair at startup. Ephemeral keys are fine for
# local dev and tests; never use them in production.
# AGENT_PASSPORT_SIGNING_KEY=/path/to/private-key.pem

# --- Issuer URL ---
# Public URL the issuer advertises in the `iss` claim. Verifiers fetch
# JWKS from <AGENT_PASSPORT_ISSUER>/.well-known/jwks.json.
# AGENT_PASSPORT_ISSUER=http://localhost:8000
